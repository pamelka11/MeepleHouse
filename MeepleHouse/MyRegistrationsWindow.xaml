<Window x:Class="MeepleHouse.MyRegistrationsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Мои записи"
        Height="479"
        Width="600"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="20">

        <StackPanel>

            <TextBlock Text="Мои записи"
                       FontSize="22"
                       FontWeight="Bold"
                       Margin="0 0 0 20"/>

            <!-- СПИСОК -->
            <ListBox x:Name="RegistrationsList" Height="300">

                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="10" Margin="5" Background="#F5F5F5" CornerRadius="5">

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- НАЗВАНИЕ СЛЕВА -->
                                <TextBlock Text="{Binding GameName}"
                           FontSize="16"
                           FontWeight="Bold"
                           VerticalAlignment="Center"/>

                                <!-- ДАТА СПРАВА -->
                                <TextBlock Text="{Binding GameDate}"
                           Grid.Column="1"
                           FontSize="13"
                           Foreground="Gray"
                           VerticalAlignment="Center"
                           Margin="10,0,0,0"/>

                            </Grid>

                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>

            </ListBox>

            <!-- КНОПКА ОТМЕНЫ -->
            <Button Content="Отменить запись"
                    Width="200"
                    Height="40"
                    Margin="0 20 0 0"
                    HorizontalAlignment="Center"
                    Click="Cancel_Click"/>

        </StackPanel>

    </Grid>
</Window>