<Window x:Class="MeepleHouse.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Регистрация"
        Height="604"
        Width="420"
        WindowStartupLocation="CenterScreen"
        Background="#F2F2F2">

    <Grid Height="579" VerticalAlignment="Top">

        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>


        <!-- ШАПКА -->

        <Grid Background="#4CAF50">

            <StackPanel VerticalAlignment="Center">

                <TextBlock Text="Meeple House"
FontSize="26"
FontWeight="Bold"
Foreground="White"
HorizontalAlignment="Center"/>

                <TextBlock Text="Кружок настольных игр"
FontSize="12"
Foreground="White"
HorizontalAlignment="Center"/>

            </StackPanel>

        </Grid>


        <!-- ФОРМА -->

        <Border Grid.Row="1"
Background="White"
Margin="40,20"
CornerRadius="10"
Padding="25">

            <StackPanel>

                <TextBlock Text="Регистрация"
FontSize="22"
FontWeight="Bold"
HorizontalAlignment="Center"
Margin="0 0 0 15"/>


                <TextBlock Text="ФИО"/>
                <TextBox x:Name="NameBox"
Height="28"
Margin="0 4 0 8"/>


                <TextBlock Text="Email"/>
                <TextBox x:Name="EmailBox"
Height="28"
Margin="0 4 0 8"/>


                <TextBlock Text="Телефон"/>
                <TextBox x:Name="PhoneBox"
Height="28"
Margin="0 4 0 8"/>


                <TextBlock Text="Логин"/>
                <TextBox x:Name="LoginBox"
Height="28"
Margin="0 4 0 8"/>


                <TextBlock Text="Пароль"/>
                <PasswordBox x:Name="PasswordBox"
Height="28"
Margin="0 4 0 15"/>


                <Button Content="Зарегистрироваться"
Height="34"
Background="#4CAF50"
Foreground="White"
Click="Register_Click"/>


                <Button Content="Назад"
Height="34"
Margin="0 8 0 0"
Click="Back_Click"/>

            </StackPanel>

        </Border>

    </Grid>
</Window>