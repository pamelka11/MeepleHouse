<Window x:Class="MeepleHouse.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Meeple House"
        Height="700"
        Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#F2F2F2">

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="90"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>


        <!-- ШАПКА -->
        <Grid Background="#4CAF50">

            <TextBlock Text="Meeple House"
FontSize="30"
FontWeight="Bold"
Foreground="White"
HorizontalAlignment="Center"
VerticalAlignment="Center"/>

            <TextBlock Text="Кружок настольных игр"
FontSize="12"
Foreground="White"
HorizontalAlignment="Center"
VerticalAlignment="Bottom"
Margin="0 0 0 15"/>

            <Button Content="Авторизация"
Width="120"
Height="35"
HorizontalAlignment="Right"
VerticalAlignment="Top"
Margin="0 20 20 0"
Click="Login_Click"/>

        </Grid>


        <!-- КАРТОЧКИ ИГР -->

        <ScrollViewer Grid.Row="1">

            <UniformGrid Columns="4" Margin="30">

    <!-- Каркассон -->
    <Button Click="Carcassonne_Click" Margin="10" Background="Transparent" BorderThickness="0">
        <StackPanel>
            <Border Height="130" CornerRadius="10" ClipToBounds="True">
                            <Image Source="ButtonImage\carcason.png"/>
            </Border>
            <TextBlock Text="Каркассон" HorizontalAlignment="Center" Margin="5"/>
        </StackPanel>
    </Button>

    <!-- Манчкин -->
    <Button Click="Munchkin_Click" Margin="10" Background="Transparent" BorderThickness="0">
        <StackPanel>
            <Border Height="130" CornerRadius="10" ClipToBounds="True">
                            <Image Source="ButtonImage\Munchcin.png"/>
            </Border>
            <TextBlock Text="Манчкин" HorizontalAlignment="Center" Margin="5"/>
        </StackPanel>
    </Button>

    <!-- Катан -->
    <Button Click="Catan_Click" Margin="10" Background="Transparent" BorderThickness="0">
        <StackPanel>
            <Border Height="130" CornerRadius="10" ClipToBounds="True">
                            <Image Source="ButtonImage\catan.png"/>
            </Border>
            <TextBlock Text="Колонизаторы" HorizontalAlignment="Center" Margin="5"/>
        </StackPanel>
    </Button>

    <!-- Мафия -->
    <Button Click="Mafia_Click" Margin="10" Background="Transparent" BorderThickness="0">
        <StackPanel>
            <Border Height="130" CornerRadius="10" ClipToBounds="True">
                            <Image Source="ButtonImage\mafia.png"/>
            </Border>
            <TextBlock Text="Мафия" HorizontalAlignment="Center" Margin="5"/>
        </StackPanel>
    </Button>

    <!-- Диксит -->
    <Button Click="Dixit_Click" Margin="10" Background="Transparent" BorderThickness="0">
        <StackPanel>
            <Border Height="130" CornerRadius="10" ClipToBounds="True">
                            <Image Source="ButtonImage\dixit.png"/>
            </Border>
            <TextBlock Text="Диксит" HorizontalAlignment="Center" Margin="5"/>
        </StackPanel>
    </Button>

    <!-- Ticket to Ride -->
    <Button Click="Ticket_Click" Margin="10" Background="Transparent" BorderThickness="0">
        <StackPanel>
            <Border Height="130" CornerRadius="10" ClipToBounds="True">
                <Image Source="ButtonImage/ticket.png"/>
            </Border>
            <TextBlock Text="Билет на поезд" HorizontalAlignment="Center" Margin="5"/>
        </StackPanel>
    </Button>

    <!-- 7 Wonders -->
    <Button Click="Seven_Click" Margin="10" Background="Transparent" BorderThickness="0">
        <StackPanel>
            <Border Height="130" CornerRadius="10" ClipToBounds="True">
                <Image Source="ButtonImage/7wonders.png"/>
            </Border>
            <TextBlock Text="7 чудес" HorizontalAlignment="Center" Margin="5"/>
        </StackPanel>
    </Button>

    <!-- Имаджинариум -->
    <Button Click="Imaginarium_Click" Margin="10" Background="Transparent" BorderThickness="0">
        <StackPanel>
            <Border Height="130" CornerRadius="10" ClipToBounds="True">
                <Image Source="ButtonImage/imaginarium.png"/>
            </Border>
            <TextBlock Text="Имаджинариум" HorizontalAlignment="Center" Margin="5"/>
        </StackPanel>
    </Button>

    <!-- Уно -->
    <Button Click="Uno_Click" Margin="10" Background="Transparent" BorderThickness="0">
        <StackPanel>
            <Border Height="130" CornerRadius="10" ClipToBounds="True">
                <Image Source="ButtonImage/uno.png"/>
            </Border>
            <TextBlock Text="Уно" HorizontalAlignment="Center" Margin="5"/>
        </StackPanel>
    </Button>

    <!-- Пандемия -->
    <Button Click="Pandemic_Click" Margin="10" Background="Transparent" BorderThickness="0">
        <StackPanel>
            <Border Height="130" CornerRadius="10" ClipToBounds="True">
                <Image Source="ButtonImage/pandemic.png"/>
            </Border>
            <TextBlock Text="Пандемия" HorizontalAlignment="Center" Margin="5"/>
        </StackPanel>
    </Button>

</UniformGrid>

        </ScrollViewer>

    </Grid>
</Window>