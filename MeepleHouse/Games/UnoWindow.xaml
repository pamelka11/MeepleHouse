<Window x:Class="MeepleHouse.Games.UnoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="UNO"
        Height="450"
        Width="800"
        WindowStartupLocation="CenterScreen"
        Background="#F2F2F2">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="70"/>
        </Grid.RowDefinitions>

        <TextBlock Text="UNO"
FontSize="28"
FontWeight="Bold"
HorizontalAlignment="Center"/>

        <Grid Grid.Row="1">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" CornerRadius="10" Margin="0 0 20 0">
                <Image Source="Image\uno.png" Stretch="Fill"/>
            </Border>

            <StackPanel Grid.Column="1">

                <TextBlock
Text="Популярная карточная игра, где нужно первым избавиться от всех карт."
FontSize="15"
TextWrapping="Wrap"
Margin="0 10 0 20"/>
                <TextBlock x:Name="DateText"
           FontSize="14"
           Margin="0 0 0 10"/>
                <TextBlock x:Name="PlayersText"
FontSize="16"
FontWeight="Bold"/>

            </StackPanel>

        </Grid>

        <Button Grid.Row="2"
Content="Записаться"
Width="200"
Height="40"
HorizontalAlignment="Right"
Background="#4CAF50"
Foreground="White"
Click="Register_Click"/>

    </Grid>
</Window>