<Window x:Class="MeepleHouse.ProfileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Профиль"
        Height="550"
        Width="420"
        WindowStartupLocation="CenterScreen"
        Background="#F2F2F2">

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ШАПКА -->

        <Grid Background="#4CAF50">

            <StackPanel VerticalAlignment="Center">

                <TextBlock Text="Meeple House"
FontSize="26"
FontWeight="Bold"
Foreground="White"
HorizontalAlignment="Center"/>

                <TextBlock Text="Кружок настольных игр"
FontSize="12"
Foreground="White"
HorizontalAlignment="Center"/>

            </StackPanel>

        </Grid>


        <!-- СОДЕРЖИМОЕ -->

        <Border Grid.Row="1"
Background="White"
Margin="40,40,40,39"
CornerRadius="10"
Padding="30">

            <StackPanel>

                <TextBlock Text="Профиль"
FontSize="22"
FontWeight="Bold"
HorizontalAlignment="Center"
Margin="0 0 0 20"/>


                <TextBlock Text="ФИО"/>
                <TextBlock x:Name="NameText"
FontSize="16"
Margin="0 5 0 15"/>


                <TextBlock Text="Email"/>
                <TextBlock x:Name="EmailText"
FontSize="16"
Margin="0 5 0 15"/>


                <TextBlock Text="Телефон"/>
                <TextBlock x:Name="PhoneText"
FontSize="16"
Margin="0 5 0 25"/>


                <Button Content="Редактировать профиль"
Height="35"
Background="#4CAF50"
Foreground="White"
Click="Edit_Click"/>

                <Button Content="Выйти"
Height="35"
Margin="0 10 0 0"
Click="Logout_Click"/>

            </StackPanel>

        </Border>

    </Grid>
</Window>